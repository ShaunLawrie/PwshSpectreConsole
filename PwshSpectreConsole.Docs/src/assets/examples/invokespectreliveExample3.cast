r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                                                                                                              \r\n                    \u001B[38;5;198m\u256D\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256E\u001B[0m                    \r\n                    \u001B[38;5;198m\u2502\u001B[0m \u001B[38;5;8mPrompt:\u001B[0m                                                            \u001B[38;5;198m\u2502\u001B[0m                    \r\n                    \u001B[38;5;198m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256F\u001B[0m                    \r\n                                                                                                              "]
